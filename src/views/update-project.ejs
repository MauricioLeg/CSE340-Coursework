<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form action="/edit-project/<%= projectDetails.project_id %>" method="POST">
    <div class="form-group">
      <label for="name">Project Title</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        minlength="3"
        maxlength="150"
        value="<%= projectDetails.title %>"
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        maxlength="500"
        required
      ><%= projectDetails.description %></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location</label>
      <input
        type="text"
        id="location"
        name="location"
        required
        value="<%= projectDetails.location %>"
      />
    </div>

    <div class="form-group">
      <label for="date">Date</label>
      <input
        type="date"
        id="date"
        name="date"
        required
        value="<%= projectDetails.date %>"
      />
    </div>

    <button type="submit">Update Project</button>
  </form>

</main>
<%- include('partials/footer') %>