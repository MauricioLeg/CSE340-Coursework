<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <p>Here are a few of our partner organizations:</p>
        <ul>
            <% organizations.forEach(organization => { %>
                <a href="/organization/<%= organization.organization_id %>"><li><img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo"><strong><%= organization.name %></strong><%= organization.contact_email %></li></a>
            <% }); %>
        </ul>
    </main>
    <p><a href="/new-organization">Add New Organization</a></p>
<%- include('partials/footer') %>
